dd --> é um comando de baixo nível usado para copiar dados diretamente entre dispositivos e arquivos, byte a byte
  dd if=origem of=destino [opções] --> Sintaxe básica
    Parâmetros principais:
      if= → input file (origem)
      of= → output file (destino)
      bs= → tamanho do bloco
      count= → quantidade de blocos
      conv= --> Deve tratar/transformar os dados durante a cópia
        notrunc --> Não truncar o arquivo de destino - dd if=arquivo of=saida conv=notrunc
        noerror --> Continua mesmo se ocorrer erro de leitura - dd if=/dev/sda of=backup.img conv=noerror
        sync --> Preenche blocos com zeros em caso de erro - dd if=/dev/sda of=backup.img conv=noerror,sync
        fsync --> Força gravação no disco ao final - dd if=arquivo of=saida conv=fsync
        fdatasync --> Similar ao fsync, mas só dados (não metadados) - dd if=arquivo of=saida conv=fdatasync
        ucase --> Converte para maiúsculo - dd if=texto.txt of=saida.txt conv=ucase
        lcase --> Converte para minúsculo - dd if=texto.txt of=saida.txt conv=lcase
        swab --> Troca bytes (endianness) - dd if=arquivo of=saida conv=swab
  dd if=arquivo.txt of=copia.txt --> Copiar arquivo simples
  dd if=/dev/sda of=/dev/sdb bs=4M --> Clonar disco inteiro
  dd if=/dev/sda of=backup.img bs=4M --> Criar imagem de disco
  dd if=backup.img of=/dev/sda bs=4M --> Restaurar imagem
  dd if=/dev/zero of=teste.img bs=1M count=1024 --> Criar arquivo de teste (1GB)
  dd if=/dev/sda of=/dev/null bs=4M --> Teste de leitura
  dd if=/dev/zero of=/dev/sdb bs=4M --> Apagar disco (zero fill)
  dd if=/dev/zero of=/dev/sdb bs=4M status=progress --> Versão mais segura para apagar disco
  dd if=/dev/urandom of=/dev/sdb bs=4M --> Apagar com dados aleatórios
  dd if=/dev/sda of=backup.img bs=4M status=progress --> Mostrar progresso

df --> Disk Free, onde lista meus filesystems
  -h --> Formato legível (K, M, G)
  -T --> Mostrar tipo de filesystem

dig --> como um nome de domínio está sendo resolvido
  dig google.com --> Uso básico
  dig www.google.com +trace --> mostra todo o caminho da resolução, desde os servidores raiz até o destino final.
  dig google.com MX --> Consultar MX (email)
  dig google.com NS --> Consultar NS (nameservers)
  dig google.com TXT --> Consultar TXT
  dig @8.8.8.8 google.com --> Usar DNS específico
  dig +short google.com --> Mostrar apenas resposta (limpo)
  dig -x 8.8.8.8 --> Consulta reversa (IP → nome)
  
dmesg --> Usado para visualizar as mensagens do kernel Linux, principalmente aquelas geradas durante o boot e eventos de hardware.
  dmesg -T --> Ver com timestamp legível
  dmesg | grep -i error --> Filtrar erros
  dmesg | tail --> Ver mensagens recentes
