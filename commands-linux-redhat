mt --> é uma ferramenta de rede que combina o ping + traceroute em tempo real.
  mtr -r google.com --> Rodar modo texto (sem interface interativa)
  mtr google.com --> Abre um interface interativa
    Colunas comuns:
      HOST → cada salto (roteador no caminho)
      Loss% → perda de pacotes
      Snt → pacotes enviados
      Last / Avg / Best / Wrst → latência
  mtr -c 10 google.com --> Definir número de ciclos
  mtr -T google.com --> Usar TCP (útil quando ICMP é bloqueado)
  mtr -P 443 google.com --> Mostrar portas

nano -- Editor padrão de arquivos

passwd -- Definição de senha

pgrep -- semelhante ao ps | grep, mas retorna apenas os IDs dos processos

ps -- Exibir informações sobre os processos em execução no sistema
  -e ou -A -- Lista todos os processos em execução no sistema
  -f -- Saida detalhada
  -u root -- Exibe os processos pertecentes a um usuário especifico
  aux -- Mostra todos os processos em execução no sistema
  -l -- Exibe informações detalhadas em formato longo
  -o -- Permite personalizar os campos exibidos na saída. EX.: ps -o pid,user,%cpu,%mem,cmd
  --sort -- Ordena a saída com base em um campo especifico, como uso de CPU ou memória. Ex.: ps aux --sort=-%cpu
    --sort=-%mem --> Ordem decrescente (-)
    --sort=%mem --> Ordem crescente

pwd -- Diretorio atual

rm -- Deletar
  -d -- Deletar pastas vazias
  -f -- Force
  -r / -R -- modo recursivo

rmdir -- Remover um diretorio vazio

rsync --> para copiar e sincronizar arquivos/diretórios, tanto localmente quanto pela rede
          O rsync lê filtros na ordem:
            rsync -av \
            --include="*/" \ #--  */ → inclui diretórios
          --include="*.log" \ #-- *.log → inclui logs
          --exclude="*" \ #-- * → exclui resto
          /data/ /backup/
  -a = archive (preserva tudo)
  -v = verbose
  -z --> Comprime os dados durante a transferência
  -u --> Copia somente arquivos mais novos
  -r --> Copia diretórios recursivamente - Já está incluído no -a, então é redundante
  -P --> Combinação de --progress → mostra progresso / --partial → permite retomar transferência
  --delete --> Remove no destino tudo que não existe mais na origem
  --dry-run --> Testar sem executar
  --progress --> Mostrar progresso
  --include --> incluir arquivos ou diretórios específicos durante a sincronização
  --exclude --> Exclui arquivos ou diretorios
  rsync [opções] origem destino --> Sintaxe básica
  rsync -av /data /backup --> Copiar diretório local
  rsync -av /data/ /backup --> copia apenas o conteúdo dentro do /data/
  rsync -av /data user@192.168.1.10:/backup --> Sincronizar com outro servidor (SSH)
  rsync -av user@192.168.1.10:/data /backup --> Copiar de remoto para local
  rsync -av --progress /data /backup --> Mostrar progresso
  rsync -av --delete /data /backup --> Sincronização “espelho” - Remove no destino o que não existe na origem
  rsync -av --exclude="*.log" /data /backup --> Ignorar arquivos
  rsync -av --dry-run /data /backup --> Testar sem executar (dry-run)
  rsync -av --delete --dry-run /data /backup --> Mostra o que será apagado/copiado sem executar
  rsync -azurP /data user@192.168.1.10:/backup --> 
  rsync -av --include="*.txt" --exclude="*" /data /backup --> copia apenas .txt e ignora todo o resto

sar --> Ele permite ver histórico e tempo real de: CPU / Memória / Disco (I/O) / Rede / Swap / Load average
  sudo systemctl enable --now sysstat -- > para funcionar o serviço precisa estar ativo
  sar -u 1 5 --> Mostra uso da CPU a cada 1 segundo, 5 vezes.
    %user → uso por aplicações
    %system → kernel
    %idle → ocioso
    %iowait → esperando disco (⚠️ importante em problemas)
  sar -r 1 5 --> Memória
  sar -d 1 5 --> Disco (I/O)
  sar -n DEV 1 5 --> Rede
  sar -u -f /var/log/sa/sa28 --> ver dados de ontem

sed --> É um editor de texto não interativo, usado para transformar texto em fluxo: (s / padrão / substituição / opções). Exemplo: sed 's/%//'
  s --> substitute (substituir)
  % --> padrão a ser encontrado. Aqui é um exemplo que é o % para ser encontrado
  `` (vazio) --> substitui por nada. Aqui é o terceiro, substituição que está vazio
  g --> entra em opções, onde substitui todas as ocorrerncias
  i --> entra em opções, onde vai ignorar maiúsculas/minúsculas

ss --> (socket statistics) é uma ferramenta moderna para ver conexões de rede (substitui o antigo netstat)
  -n --> Mostra IPs e portas em formato numérico (numeric)
  -a --> Mostra todas as conexões (all)
  -o --> Mostra informações de temporizadores TCP (timer)
  -t --> Filtra apenas conexões TCP
  -p --> Exibe o processo que esta na porta

swapon --> usado para ativar a memória swap no Linux
  swapon /dev/sda2 --> Ativar uma partição swap
  swapon /swapfile --> Ativar um arquivo swap
  swapon --show --> Ver swap ativo
  swapoff /swapfile --> Desativar swap
  swapoff -a --> Desativar todos os swap

tail --> Exibe as ultimas linhas de um arquivo
  -n --> Quantidade de linhas para exibir. Ex.: tail -n 10 /var/log/syslog | grep "error"

tar -- Para arquivar e gerenciar múltiplos arquivos ou diretórios em um único arquivo Ex.: tar -czf "$arquivo_backup" "$diretorio_backup"
  -c -- Criar
  -x -- Extrair
  -v -- Verificar ou listar
  -f -- Define o nome do arquivo (sempre usado antes do nome do arquivo).
  -v -- Modo verboso, mostra o progresso.
  -z -- Comprime o arquivo usando gzip.
  -j -- Comprime o arquivo usando bzip2 (maior compressão, mas mais lento).
  -C -- Especifica um diretório de destino para a extração.
  --no-same-owner --> não preserve o dono original (owner) dos arquivos / atribua os arquivos ao usuário atual
  tar -xvf backup.tar --no-same-owner -- > Exemplo com o no some owner
  tar [opções] arquivo.tar arquivos/ --> Estrutura básica
  tar -cvf backup.tar /data --> Criar arquivo .tar (sem compressão)
  tar -czvf backup.tar.gz /data --> Criar .tar.gz (gzip)
  tar -cjvf backup.tar.bz2 /data --> Criar .tar.bz2 (bzip2)
  tar -xvf backup.tar --> Extrair .tar
  tar -xzvf backup.tar.gz --> Extrair .tar.gz
  tar -xzvf backup.tar.gz -C /tmp --> Extrair em diretório específico
  tar -tvf backup.tar.gz --> Listar conteúdo sem extrair
  tar -xvf backup.tar arquivo.txt --> Extrair arquivo específico
  tar --exclude="*.log" -czvf backup.tar.gz /data --> Excluir arquivos ao criar
  tar -uvf backup.tar arquivo_novo.txt --> Atualizar arquivo tar
  tar -czvf backup.tar.gz /etc /var /home --> Compactar múltiplos diretórios

targetcli --> é uma ferramenta de linha de comando usada para configurar um servidor iSCSI no Linux, baseada no framework moderno LIO (Linux-IO Target).
  targetcli --> Você entra em um shell tipo: Navegação estilo diretórios (cd, ls)
  /backstores/block create disk01 /dev/sdb --> Criar backend (disco)
  /iscsi create iqn.2026-01.local:storage --> Criar target iSCSI
  /iscsi/iqn.2026-01.local:storage/tpg1/luns create /backstores/block/disk01 --> Criar LUN
  /iscsi/iqn.2026-01.local:storage/tpg1/acls create iqn.client --> Liberar acesso
  set attribute authentication=0 --> liberar geral
  saveconfig --> Salvar configuração
  /etc/target/saveconfig.json --> Configuração persistente:
  systemctl enable --now target --> Serviço

tcpdump --> linha de comando usada para capturar e analisar pacotes de rede em tempo real
  tcpdump -i eth0 --> Capturar em uma interface
  tcpdump -n -i eth0 --> Não resolver DNS (mais rápido)
  tcpdump host 192.168.1.10 --> Filtrar por IP
  tcpdump port 80 --> Filtrar por porta
  tcpdump icmp --> Filtrar por protocolo
  tcpdump -i eth0 src host 192.168.1.10 --> Ver apenas saída (TX)
  tcpdump -i eth0 dst host 192.168.1.10 --> Ver apenas entrada (RX)
  tcpdump -i eth0 -w captura.pcap --> Capturar e salvar arquivo
  tcpdump -r captura.pcap --> Ler arquivo capturado

touch -- Cria arquivos vazios. Ex.: touch data1 data2

useradd -- Cria um usuário local
  -m -- Cria o diretorio home do usuário

watch -- Executa outro comando repetidamente, mostrando o resultado na tela
  watch -n 1 ss -naot --> Atualizar mais rápido
