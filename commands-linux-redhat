
> /dev/null -- Local de descarte de saidas corretas
&> /dev/null -- Local de descarte de saidas validas e quanto erros
<<< --> redireciona o conteudo da variavel

awk --> Trabalha linha a linha e divide cada linha em campos (colunas)
  $0 --> linha inteira
  $1 --> primeira coluna
  $NF --> última coluna
  NR --> Número da linha. Ex.: NR==2 -- Executa a ação somente na segunda linha
  NF --> Número de campos
  FS --> Separador de campo
  OFS --> Separador de saída
  {print $3} --> Imprime o terceiro campo da linha (separados por espaços)

blkid --> é usado para identificar dispositivos de bloco e mostrar informações do sistema de arquivos, como UUID, tipo e label
  blkid /dev/sda1 --> Ver um disco específico
  blkid -t TYPE=xfs --> Filtrar por tipo
  blkid -s UUID -o value /dev/sda1 --> Mostrar apenas UUID
  

cat --> Exibe o conteúdo de um arquivo no terminal

chkconfig --> é um comando usado em sistemas Linux mais antigos (ou compatibilidade no RHEL) para gerenciar quais serviços iniciam automaticamente no boot
              O systemd substituiu o chkconfig
  chkconfig --list --> Listar serviços
  chkconfig --list sshd --> Ver um serviço específico
  chkconfig sshd on --> Ativar serviço no boot
  chkconfig sshd off --> Desativar

convert --> Esse comando nos permite converter, editar e exibir imagens em diversos formatos (pacote imagemagick). EX: convert imagem.jpg imagem.png
  -resize --> Redimensionar a imagem. Ex.: convert imagem.jpg -resize 800x600 imagem_redimensionada.jpg

cp --> Copia um arquivo ou diretorio
  -r --> Recursivo. Ex.: cp -r dir1/* dir2

curl -- Usado para fazer requisição http
  -s -- modo silencioso, suprime mensagens de progressos ou erros

df --> Disk Free, onde lista meus filesystems
  -h --> Formato legível (K, M, G)
  -T --> Mostrar tipo de filesystem

dmesg --> Usado para visualizar as mensagens do kernel Linux, principalmente aquelas geradas durante o boot e eventos de hardware.
  dmesg -T --> Ver com timestamp legível
  dmesg | grep -i error --> Filtrar erros
  dmesg | tail --> Ver mensagens recentes
  dmesg -w --> Acompanhar em tempo real
  dmesg | grep -i sda --> Problema de disco
  dmesg | grep -i eth --> Problema de rede

du --> Espaço ocupado por arquivos/diretórios

echo --> Exibe a string especificada

free --> usado para ver o uso de memória RAM e swap no sistema Linux
  free -h --> Forma mais usada (legível)

grep --> Usado para buscar e filtrar
  -i -- Ignora a diferença entre maiusculas e minusculas
  -v -- Inverte a busca, exibindo as linhas que não correspondem ao padrão. Ex: ps aux | grep -v grep | grep nginx
  -A3 -- Mostra 3 linhas DEPOIS da linha encontrada.
  -B3 -- Mostra 3 linhas ANTES da linha encontrada.

head --> Para exibir as primeiras linhas de um arquivo de texto ou de uma saída de um comando
  -n --> quantidade de linhas a ser exibido. Ex.: head -n 5 arquivo.txt
  -c --> quantidade de bytes a ser exibido. Ex.: head -c 20 arquivo.txt

iftop --> monitorar o tráfego de rede em tempo real
  -i eth0 --> interface para monitoramento
  -P --> Mostrar porta
  -N --> Mostrar IP e hostname

ip --> Com ele você consegue: Ver e configurar interfaces de rede / Gerenciar endereços IP / Manipular rotas (gateway) / Ver conexões e regras de rede
        Trabalhar com VLANs, bridges e túneis
  ip addr / ip a --> Ver interfaces e IPs
  ip link --> Ver status das interfaces
  ip link set eth0 up / ip link set eth0 down --> Subir ou derrubar interface
  ip addr add 192.168.1.10/24 dev eth0 --> Adicionar IP manualmente
  ip addr del 192.168.1.10/24 dev eth0 --> Remover IP
  ip route --> Ver rotas (gateway)
  ip route add default via 192.168.1.1 --> Adicionar rota padrão
  ip neigh --> Ver tabela de vizinhos (ARP)

journalctl --> ferramenta usada em sistemas Linux com systemd para visualizar e consultar logs do sistema de forma centralizada.
  journalctl -n 50 --> Ver logs recentes
  journalctl -f --> Acompanhar em tempo real (tipo tail -f)
  journalctl -u sshd --> Logs de um serviço específico
  journalctl -b --> Logs do boot atual
  journalctl -k --> Logs do kernel
  journalctl --since "2026-04-29 14:00" / journalctl --since yesterday --> Filtrar por data
  journalctl -p err --> Filtrar por erro

localectl status -- Para verificar como está a config atual
  localectl set-keymap br-abnt2 -- alterar para o abnt2

ls -- Lista conteudo de um diretorio
  -l -- formato lista longa
  -a -- listar tudo
  -t -- Ordenar a lista em ordem cronologica - time

lsblk --> usado para listar dispositivos de bloco no Linux, ou seja, tudo relacionado a discos, partições e volumes.
  lsblk -f --> Mostrar filesystem (tipo ext4, xfs)
  lsblk -o NAME,SIZE,FSTYPE,UUID,MOUNTPOINT --> Mostrar UUID
  lsblk -d --> Ver apenas discos
  lsblk -a --> Ver em formato mais detalhado

lsmod --> serve para listar os módulos do kernel Linux que estão carregados no momento.

lsof --> Arquivos abertos por processos / Portas de rede em uso / Qual processo está usando um recurso / Arquivos deletados ainda em uso
          Dispositivos (discos, sockets, pipes)
  lsof -i :80 --> Ver quem está usando uma porta
  lsof -iTCP -sTCP:ESTABLISHED --> Para listar conexões TCP já estabelecidas (ativas) no sistema
  lsof -p 1234 --> Ver arquivos de um processo
  lsof /var/log/messages --> Ver qual processo está usando um arquivo
  lsof -u galdper --> Ver arquivos abertos por um usuário
  lsof | grep deleted --> Ver arquivos deletados ainda em uso

systemctl --> É o comando principal usado para interagir com o systemd, ou seja, para controlar serviços e o estado do sistema no Linux
  systemctl cat nome_do_servico --> Se um serviço está estranho. Ele mostra: arquivo original (/lib) / overrides (/etc)
  systemctl daemon-reload --> Para recarregar os arquivos de configuração (unit files) sem precisar reiniciar o sistema.
  systemctl list-units --type=service --> Ver todos os serviços

sudoedit --> forma segura de editar arquivos como root usando o sudo, sem abrir diretamente o arquivo com permissões elevadas.

mv - Mover aquivo ou pasta

mkdir -- Criação de diretorios
  -p -- Cria toda a cadeia de diretorios ex.: /devops/app/src

mount --> usado no Linux para montar sistemas de arquivos, ou seja, tornar um disco, partição ou recurso acessível dentro do sistema
  mount OU mount | grep /dev --> Ver montagens atuais
  mount -t xfs /dev/sdb1 /data --> Montar com tipo de filesystem
  mount -a --> Montar usando fstab
  mount -o ro /dev/sdb1 /data --> Montar somente leitura
  mount -t nfs 192.168.1.10:/export /mnt --> Montar NFS
  umount /data | umount /dev/sdb1 --> Desmontar (unmount)
  
mt --> é uma ferramenta de rede que combina o ping + traceroute em tempo real.
  mtr -r google.com --> Rodar modo texto (sem interface interativa)
  mtr google.com --> Abre um interface interativa
    Colunas comuns:
      HOST → cada salto (roteador no caminho)
      Loss% → perda de pacotes
      Snt → pacotes enviados
      Last / Avg / Best / Wrst → latência
  mtr -c 10 google.com --> Definir número de ciclos
  mtr -T google.com --> Usar TCP (útil quando ICMP é bloqueado)
  mtr -P 443 google.com --> Mostrar portas

nano -- Editor padrão de arquivos

passwd -- Definição de senha

pgrep -- semelhante ao ps | grep, mas retorna apenas os IDs dos processos

ps -- Exibir informações sobre os processos em execução no sistema
  -e ou -A -- Lista todos os processos em execução no sistema
  -f -- Saida detalhada
  -u root -- Exibe os processos pertecentes a um usuário especifico
  aux -- Mostra todos os processos em execução no sistema
  -l -- Exibe informações detalhadas em formato longo
  -o -- Permite personalizar os campos exibidos na saída. EX.: ps -o pid,user,%cpu,%mem,cmd
  --sort -- Ordena a saída com base em um campo especifico, como uso de CPU ou memória. Ex.: ps aux --sort=-%cpu
    --sort=-%mem --> Ordem decrescente (-)
    --sort=%mem --> Ordem crescente

pwd -- Diretorio atual

rm -- Deletar
  -d -- Deletar pastas vazias
  -f -- Force
  -r / -R -- modo recursivo

rmdir -- Remover um diretorio vazio

sar --> Ele permite ver histórico e tempo real de: CPU / Memória / Disco (I/O) / Rede / Swap / Load average
  sudo systemctl enable --now sysstat -- > para funcionar o serviço precisa estar ativo
  sar -u 1 5 --> Mostra uso da CPU a cada 1 segundo, 5 vezes.
    %user → uso por aplicações
    %system → kernel
    %idle → ocioso
    %iowait → esperando disco (⚠️ importante em problemas)
  sar -r 1 5 --> Memória
  sar -d 1 5 --> Disco (I/O)
  sar -n DEV 1 5 --> Rede
  sar -u -f /var/log/sa/sa28 --> ver dados de ontem

sed --> É um editor de texto não interativo, usado para transformar texto em fluxo: (s / padrão / substituição / opções). Exemplo: sed 's/%//'
  s --> substitute (substituir)
  % --> padrão a ser encontrado. Aqui é um exemplo que é o % para ser encontrado
  `` (vazio) --> substitui por nada. Aqui é o terceiro, substituição que está vazio
  g --> entra em opções, onde substitui todas as ocorrerncias
  i --> entra em opções, onde vai ignorar maiúsculas/minúsculas

ss --> (socket statistics) é uma ferramenta moderna para ver conexões de rede (substitui o antigo netstat)
  -n --> Mostra IPs e portas em formato numérico (numeric)
  -a --> Mostra todas as conexões (all)
  -o --> Mostra informações de temporizadores TCP (timer)
  -t --> Filtra apenas conexões TCP
  -p --> Exibe o processo que esta na porta

swapon --> usado para ativar a memória swap no Linux
  swapon /dev/sda2 --> Ativar uma partição swap
  swapon /swapfile --> Ativar um arquivo swap
  swapon --show --> Ver swap ativo
  swapoff /swapfile --> Desativar swap
  swapoff -a --> Desativar todos os swap

tail --> Exibe as ultimas linhas de um arquivo
  -n --> Quantidade de linhas para exibir. Ex.: tail -n 10 /var/log/syslog | grep "error"

tar -- Para arquivar e gerenciar múltiplos arquivos ou diretórios em um único arquivo Ex.: tar -czf "$arquivo_backup" "$diretorio_backup"
  -c -- Criar
  -x -- Extrair
  -v -- Verificar ou listar
  -f -- Define o nome do arquivo (sempre usado antes do nome do arquivo).
  -v -- Modo verboso, mostra o progresso.
  -z -- Comprime o arquivo usando gzip.
  -j -- Comprime o arquivo usando bzip2 (maior compressão, mas mais lento).
  -C -- Especifica um diretório de destino para a extração. 

touch -- Cria arquivos vazios. Ex.: touch data1 data2

useradd -- Cria um usuário local
  -m -- Cria o diretorio home do usuário

watch -- Executa outro comando repetidamente, mostrando o resultado na tela
  watch -n 1 ss -naot --> Atualizar mais rápido
  watch -d ss -naot --> Destacar mudanças

